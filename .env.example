# Core
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/personal_website

# Initial admin bootstrap (used only when admin_users is empty)
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-this-initial-password

# Auth and sessions
AUTH_SESSION_DAYS=30
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5
SESSION_PRUNE_INTERVAL_MINUTES=30

# Networking
# Local development example:
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# Production example:
# CORS_ALLOWED_ORIGINS=https://domtarang.com,https://www.domtarang.com
TRUST_PROXY=false
REQUEST_BODY_LIMIT=100kb
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000

# Logging
LOG_LEVEL=info
